# BHUB - Variáveis de Ambiente de Produção
# Copie este arquivo para .env e configure as variáveis

# ============================================
# Backend Configuration
# ============================================

# Secret Key (gerar com: openssl rand -hex 32)
SECRET_KEY=change-this-secret-key-in-production

# Cron Secret (gerar com: openssl rand -hex 16)
CRON_SECRET=change-this-cron-secret-in-production

# Debug Mode
DEBUG=false

# Environment
ENVIRONMENT=production

# Allowed Origins (separar por vírgula)
ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com

# ============================================
# AI Services API Keys
# ============================================

# DeepSeek API Key
DEEPSEEK_API_KEY=

# OpenRouter API Key
OPENROUTER_API_KEY=

# HuggingFace API Key
HUGGINGFACE_API_KEY=

# ============================================
# Scheduler Configuration
# ============================================

# Enable Scheduler
ENABLE_SCHEDULER=true

# Sync Interval (hours)
SYNC_INTERVAL_HOURS=1

# ============================================
# Frontend Configuration
# ============================================

# API URL (usar o domínio público ou nome do serviço Docker)
NEXT_PUBLIC_API_URL=https://seudominio.com/api/v1

# Enable Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ============================================
# Docker Configuration (opcional)
# ============================================

# Backend URL para Next.js rewrites (usar nome do serviço Docker)
BACKEND_URL=http://backend:8000
